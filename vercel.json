{
  "rewrites": [
    { "source": "/chauffeur", "destination": "/chauffeur/index.html" },
    { "source": "/chauffeur/", "destination": "/chauffeur/index.html" },
    {
      "has": [{ "type": "host", "value": "aichauffeur.ai" }],
      "source": "/(.*)",
      "destination": "/chauffeur/index.html"
    },
    {
      "has": [{ "type": "host", "value": "www.aichauffeur.ai" }],
      "source": "/(.*)",
      "destination": "/chauffeur/index.html"
    }
  ]
}
